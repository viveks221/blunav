{
  "name": "blunav-node",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js --watch src",
    "test": "jest --coverage",
    "demo": "bash scripts/demo.sh",
    "migrate": "node src/db/migrate.js",
    "retry-poller": "node src/workers/retryPoller.js",
    "start-consumer": "node src/workers/kafkaConsumer.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:watch": "eslint . --watch"
  },
  "dependencies": {
    "dotenv": "16.4.5",
    "eslint": "^10.3.0",
    "express": "4.19.2",
    "ioredis": "5.3.2",
    "kafkajs": "2.2.4",
    "pg": "8.11.5",
    "pg-hstore": "2.3.4",
    "sequelize": "6.37.3",
    "umzug": "3.8.1",
    "uuid": "10.0.0",
    "winston": "3.13.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "ioredis-mock": "8.9.0",
    "jest": "29.7.0",
    "nodemon": "2.0.22"
  }
  ,
  "jest": {
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [".js"],
    "transform": {}
  }
}
